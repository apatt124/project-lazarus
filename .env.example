# Project Lazarus - Environment Configuration
# Copy this file to .env and fill in your values

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=

# Project Configuration
PROJECT_NAME=ProjectLazarus
ENVIRONMENT=Personal

# S3 Configuration
S3_BUCKET_NAME=project-lazarus-medical-docs-${AWS_ACCOUNT_ID}

# KMS Configuration
KMS_KEY_ALIAS=alias/project-lazarus

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Google Calendar API (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Frontend Configuration (if deploying web app)
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_AGENT_ID=
NEXT_PUBLIC_AGENT_ALIAS_ID=

# Monitoring
LOG_LEVEL=INFO
ENABLE_XRAY=true

# Cost Alerts
MONTHLY_BUDGET_LIMIT=200
ALERT_EMAIL=
