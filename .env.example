# API Configuration
# Replace with your API Gateway URL after creating Lambda functions
VITE_API_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/prod

# Database Configuration (for local development/scripts)
DB_HOST=your-rds-endpoint.region.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=your_db_user
DB_PASSWORD=your_secure_password

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your_account_id

# Lambda Configuration
AWS_LAMBDA_FUNCTION_NAME=your-vector-search-function

# S3 Configuration
S3_BUCKET_NAME=your-s3-bucket-name

# API Gateway Configuration
API_GATEWAY_ID=your-api-gateway-id

# Application Password (for simple auth)
APP_PASSWORD=your_secure_app_password
